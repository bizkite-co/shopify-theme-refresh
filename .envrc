#!/bin/bash
source_up_if_exists
# Override parent settings
unset SHOPIFY_SHOP
unset SHOPIFY_THEME_ID

# Detect current branch and load appropriate env file
BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")

if [ "$BRANCH" = "main" ]; then
    if [ -f "prod.env" ]; then
        source_env prod.env
        export SHOPIFY_SHOP=turbo-heat-welding-tools.myshopify.com
        echo "Loaded prod.env (branch: main), SHOPIFY_SHOP=$SHOPIFY_SHOP"
    else
        echo "Warning: prod.env not found"
    fi
elif [ "$BRANCH" = "uat" ]; then
    if [ -f "uat.env" ]; then
        source_env uat.env
        export SHOPIFY_SHOP=turboship-uat.myshopify.com
        echo "Loaded uat.env (branch: uat), SHOPIFY_SHOP=$SHOPIFY_SHOP"
    else
        echo "Warning: uat.env not found"
    fi
else
    echo "Warning: Unknown branch '$BRANCH' - defaulting to uat"
    if [ -f "uat.env" ]; then
        source_env uat.env
        export SHOPIFY_SHOP=turboship-uat.myshopify.com
    fi
fi
